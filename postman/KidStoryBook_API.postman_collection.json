{
  "info": {
    "name": "KidStoryBook API",
    "description": "Complete API collection for KidStoryBook - AI-powered personalized children's storybook platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "kidstorybook-api-v1"
  },
  "item": [
    {
      "name": "Authentication",
      "description": "Authentication helper requests",
      "item": [
        {
          "name": "Get Auth Token (Test Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data?.session?.access_token) {",
                  "        pm.environment.set('auth_token', response.data.session.access_token);",
                  "        pm.environment.set('user_id', response.data.user.id);",
                  "        console.log('Auth token saved:', response.data.session.access_token.substring(0, 20) + '...');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/test-login",
              "host": ["{{base_url}}"],
              "path": ["auth", "test-login"]
            },
            "description": "⚠️ Development Only: Login to get authentication token for testing. Token will be automatically saved to environment. This endpoint only works in development mode."
          }
        }
      ]
    },
    {
      "name": "Characters",
      "description": "Character management endpoints",
      "item": [
        {
          "name": "Analyze Character Photo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has character data', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success', true);",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    if (jsonData.data?.id) {",
                  "        pm.environment.set('character_id', jsonData.data.id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"photoUrl\": \"https://example.com/photo.jpg\",\n  \"name\": \"Arya\",\n  \"age\": 5,\n  \"gender\": \"girl\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/characters/analyze",
              "host": ["{{base_url}}"],
              "path": ["characters", "analyze"]
            },
            "description": "Analyzes a reference photo and creates a master character description using AI."
          }
        },
        {
          "name": "Get All Characters",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/characters",
              "host": ["{{base_url}}"],
              "path": ["characters"]
            },
            "description": "Returns all characters for the authenticated user."
          }
        },
        {
          "name": "Get Character by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/characters/{{character_id}}",
              "host": ["{{base_url}}"],
              "path": ["characters", "{{character_id}}"]
            },
            "description": "Returns detailed information about a specific character."
          }
        },
        {
          "name": "Update Character",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"age\": 6\n}"
            },
            "url": {
              "raw": "{{base_url}}/characters/{{character_id}}",
              "host": ["{{base_url}}"],
              "path": ["characters", "{{character_id}}"]
            },
            "description": "Updates character properties."
          }
        },
        {
          "name": "Delete Character",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/characters/{{character_id}}",
              "host": ["{{base_url}}"],
              "path": ["characters", "{{character_id}}"]
            },
            "description": "Deletes a character permanently."
          }
        },
        {
          "name": "Set Default Character",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/characters/{{character_id}}/set-default",
              "host": ["{{base_url}}"],
              "path": ["characters", "{{character_id}}", "set-default"]
            },
            "description": "Sets a character as the user's default character."
          }
        }
      ]
