                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"characterId\": \"{{character_id}}\",\n  \"theme\": \"adventure\",\n  \"illustrationStyle\": \"watercolor\",\n  \"customRequests\": \"Make it exciting\",\n  \"language\": \"en\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/books",
              "host": ["{{base_url}}"],
              "path": ["books"]
