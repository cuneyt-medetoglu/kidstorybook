{
  "name": "herokidstory",
  "version": "1.0.0",
  "description": "AI destekli kişiselleştirilmiş çocuk hikaye kitapları oluşturma platformu.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "generate-style-examples": "tsx scripts/generate-style-examples.ts",
    "generate-hero-transformation": "tsx scripts/generate-hero-transformation.ts",
    "optimize-images": "node scripts/optimize-hero-images.mjs",
    "copy-examples-to-locale": "tsx scripts/copy-examples-to-locale.ts",
    "roadmap": "node scripts/generate-roadmap-csv.js",
    "ssh:server": "ssh -i herokidstory-key.pem ubuntu@18.184.150.1",
    "ssh:tunnel": "ssh -i herokidstory-key.pem -L 5432:localhost:5432 ubuntu@18.184.150.1",
    "clean": "npx rimraf .next",
    "clean:all": "npx rimraf node_modules .next",
    "build:local": "npx next build",
    "deploy:build": "npm run clean:all && npm install --include=dev && npm run build",
    "deploy:build:fast": "npm install --include=dev && npm run build",
    "worker": "tsx worker.ts",
    "worker:dev": "tsx watch worker.ts",
    "deploy:restart": "pm2 restart herokidstory herokidstory-worker",
    "deploy": "npm run deploy:build && npm run deploy:restart",
    "deploy:fast": "npm run deploy:build:fast && npm run deploy:restart"
  },
  "repository": {
    "type": "git",
    "url": "git+https://cuneyt-medetoglu@github.com/cuneyt-medetoglu/herokidstory.git"
  },
  "keywords": [],
